# Core Django
SECRET_KEY=replace-with-strong-secret
DEBUG=False
ALLOWED_HOSTS=senderplus-django-api.onrender.com

# Database (Render Postgres recommended)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://senderplus.netlify.app,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://senderplus-django-api.onrender.com,https://senderplus.netlify.app
CORS_ALLOW_ALL_ORIGINS=False

# Security cookies
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Cloudinary (already used in repo)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@senderplus.app
